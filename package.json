{
  "name": "claude-hive-mind",
  "version": "0.1.0",
  "description": "Real-time coordination layer for multiple AI coding assistant instances",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-hive-mind": "dist/cli.js",
    "chm": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/ --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src/ tests/ --fix --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{src,tests}/**/*.ts\"",
    "format:check": "prettier --check \"{src,tests}/**/*.ts\"",
    "clean": "rm -rf dist coverage"
  },
  "keywords": [
    "mcp",
    "claude",
    "ai",
    "coordination",
    "multi-agent",
    "real-time",
    "hive-mind"
  ],
  "author": "dev-smurf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-smurf/claude-hive-mind.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "jiti": "^2.6.1",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.0.0"
  }
}
