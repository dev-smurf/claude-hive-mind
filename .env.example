# Claude Hive Mind — Environment Configuration
# Copy to .env and adjust as needed. All values have sensible defaults.

# ─── Server ──────────────────────────────────────────────────────────────────
# CHM_PORT=7777
# CHM_HOST=0.0.0.0

# ─── Database ────────────────────────────────────────────────────────────────
# CHM_DB_PATH=hivemind.db

# ─── Security ────────────────────────────────────────────────────────────────
# Auth token for API/WebSocket access. Auto-generated if not set.
# CHM_AUTH_TOKEN=your-secret-token-here
# CHM_AUTH_ENABLED=true
# Comma-separated allowed CORS origins
# CHM_CORS_ORIGINS=http://localhost:7777
# CHM_RATE_LIMIT_WINDOW_MS=60000
# CHM_RATE_LIMIT_MAX=200

# ─── Agent Lifecycle ─────────────────────────────────────────────────────────
# CHM_HEARTBEAT_INTERVAL_MS=10000
# CHM_HEARTBEAT_TIMEOUT_MS=30000
# CHM_STALE_CLEANUP_MS=60000

# ─── File Ownership ──────────────────────────────────────────────────────────
# CHM_DEFAULT_CLAIM_TTL_MS=300000
# CHM_MAX_CLAIMS_PER_AGENT=50

# ─── Knowledge Store ─────────────────────────────────────────────────────────
# CHM_DEFAULT_KNOWLEDGE_TTL_S=3600
# CHM_MAX_KNOWLEDGE_ENTRIES=1000

# ─── WebSocket ───────────────────────────────────────────────────────────────
# CHM_WS_MAX_PAYLOAD_BYTES=1048576
# CHM_WS_PING_INTERVAL_MS=15000

# ─── Dashboard ───────────────────────────────────────────────────────────────
# CHM_DASHBOARD_ENABLED=true

# ─── Environment ─────────────────────────────────────────────────────────────
# NODE_ENV=development
# CHM_LOG_LEVEL=info
